#!/bin/bash
# Block direct pushes to main — use PRs instead

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if [ "$current_branch" = "$protected_branch" ]; then
    echo ""
    echo "🚫 Direct push to '$protected_branch' is blocked."
    echo "   Create a feature branch and open a PR instead:"
    echo ""
    echo "   git checkout -b feature/my-change"
    echo "   git push -u origin feature/my-change"
    echo "   gh pr create"
    echo ""
    echo "   To bypass (emergency only): git push --no-verify"
    echo ""
    exit 1
fi

exit 0